@startuml TrackWise_Seq_SubscriptionCreation

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 5
skinparam sequenceMessageAlign center

skinparam participant {
  BackgroundColor #E8F0FE
  BorderColor #1E3A8A
}

title **Sequence Diagram -- Register Subscription (UC-04)**

actor "End User" as USER
participant "SubscriptionController" as CTRL
participant "SecurityContext" as SEC
participant "SubscriptionServiceImpl" as SVC
participant "AssetService" as ASSET_SVC
participant "TagService" as TAG_SVC
participant "RecurrenceRuleService" as REC_SVC
participant "SubscriptionMapper" as MAPPER
participant "SubscriptionRepository" as REPO
database "PostgreSQL" as DB

USER -> CTRL : POST /api/subscriptions\n{CreateSubscriptionRequest}
activate CTRL

CTRL -> SEC : getCurrentUserId()
activate SEC
return userId

CTRL -> SVC : createSubscription(userId, request)
activate SVC

SVC -> SVC : validate(request)
note right
  Validate:
  - name is present
  - costPerCycle >= 0
  - recurrenceRule is present
end note

== Optional: Resolve Asset Link ==

opt request.assetId is provided
  SVC -> ASSET_SVC : getAsset(userId, assetId)
  activate ASSET_SVC
  alt asset not found or wrong user
    ASSET_SVC --> SVC : throw ResourceNotFoundException
    SVC --> CTRL : propagate exception
    CTRL --> USER : 404 Not Found
  else
    return assetResponse
  end
end

== Optional: Resolve Tags ==

opt request.tagIds is provided
  SVC -> TAG_SVC : getTagsByIds(userId, tagIds)
  activate TAG_SVC
  return Set<Tag>
end

== Create Recurrence Rule ==

SVC -> REC_SVC : createRule(request.recurrenceRule)
activate REC_SVC
return recurrenceRule

== Create Subscription Entity ==

SVC -> MAPPER : toEntity(request, userId)
activate MAPPER
return subscription

SVC -> SVC : subscription.setTags(tags)
SVC -> SVC : subscription.setRecurrenceRule(recurrenceRule)
SVC -> SVC : subscription.setStatus(ACTIVE)

SVC -> REC_SVC : calculateNextOccurrence(recurrenceRule, today)
activate REC_SVC
return nextRenewalDate

SVC -> SVC : subscription.setNextRenewalDate(nextRenewalDate)

SVC -> REPO : save(subscription)
activate REPO
REPO -> DB : INSERT INTO subscription
activate DB
return savedSubscription
return savedSubscription

SVC -> MAPPER : toResponse(savedSubscription)
activate MAPPER
return subscriptionResponse

return subscriptionResponse

CTRL --> USER : 201 Created\n{SubscriptionResponse}
deactivate CTRL

@enduml
